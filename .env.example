# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# API key for all endpoints (leave blank to run without auth in dev/demo)
API_KEY=

# Allowed frontend origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# File size limits (MB)
MAX_IMAGE_MB=10
MAX_VIDEO_MB=200

# Override default paths (optional — defaults to subdirs of the project root)
# DB_PATH=evidence_store/violations.db
# SNAP_DIR=evidence_store/snapshots
# HELMET_MODEL=runs/detect/runs/helmet_train/violavision_v1/weights/best.pt
# SEATBELT_MODEL=runs/detect/runs/seatbelt_train/violavision_seatbelt_v1-2/weights/best.pt
# WRONGSIDE_MODEL=runs/detect/runs/wrongside_train/violavision_wrongside_v1/weights/best.pt
